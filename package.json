{
  "name": "mikes-pub-website",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=24.18.0 <25",
    "npm": ">=11.16.0 <12"
  },
  "packageManager": "npm@11.16.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm run lint:code && npm run lint:styles",
    "lint:code": "eslint .",
    "lint:styles": "stylelint \"src/**/*.css\" --allow-empty-input",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "npm run build && playwright test",
    "verify": "npm run format:check && npm run lint && npm run check && npm run test:unit && npm run build"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "astro": "7.0.7",
    "eslint": "10.7.0",
    "eslint-plugin-astro": "3.0.0",
    "prettier": "3.9.5",
    "prettier-plugin-astro": "0.14.1",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.2": true,
    "fsevents@2.3.3": true
  }
}
