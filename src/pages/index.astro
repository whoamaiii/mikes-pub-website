---
import { getImage } from 'astro:assets';

import GamesPromo from '../components/home/GamesPromo.astro';
import HomeHero from '../components/home/HomeHero.astro';
import ProgramRail from '../components/home/ProgramRail.astro';
import SportPromo from '../components/home/SportPromo.astro';
import LocationPanel from '../components/location/LocationPanel.astro';
import VenueMap from '../components/location/VenueMap.astro';
import SiteHeader from '../components/navigation/SiteHeader.astro';
import ConceptBanner from '../components/site/ConceptBanner.astro';
import SiteFooter from '../components/site/SiteFooter.astro';
import VisitActions from '../components/visit/VisitActions.astro';
import { homeHero, homeProgramItems, sportPromo } from '../data/home';
import {
  gamesPromo,
  siteFooterNavigation,
  siteNavigation,
  venueLinks,
  venueLocationLabels,
  venueMapLabels,
  venueVisitInfo,
  verifiedSiteLocation,
} from '../data/site';
import SiteLayout from '../layouts/SiteLayout.astro';

const mainId = 'main-content';
const heroSizes = '100vw';
const [mobileHeroImage, desktopHeroImage] = await Promise.all([
  getImage({
    src: homeHero.image.mobile,
    widths: [360, 540, 720, 900, 1080],
    format: 'webp',
    quality: 82,
  }),
  getImage({
    src: homeHero.image.desktop,
    widths: [1024, 1280, 1440, 1600, 1920],
    format: 'webp',
    quality: 82,
  }),
]);
const responsiveHeroSources = {
  mobile: {
    src: mobileHeroImage.src,
    srcset: mobileHeroImage.srcSet.attribute,
    sizes: heroSizes,
  },
  desktop: {
    src: desktopHeroImage.src,
    srcset: desktopHeroImage.srcSet.attribute,
    sizes: heroSizes,
  },
};
const heroImagePresentation = {
  alt: homeHero.image.alt,
  focalPoint: homeHero.image.focalPoint,
  rightsStatus: homeHero.image.rightsStatus,
  mobile: {
    width: Number(mobileHeroImage.attributes.width),
    height: Number(mobileHeroImage.attributes.height),
  },
  desktop: {
    width: Number(desktopHeroImage.attributes.width),
    height: Number(desktopHeroImage.attributes.height),
  },
};
---

<SiteLayout
  title="Mike’s Pub i Sætre | privat designforslag"
  description="Privat designforslag for Mike’s Pub i Sætre, med besøksinformasjon og et program som bare viser bekreftede arrangementer."
  criticalImages={[
    {
      href: mobileHeroImage.src,
      srcset: mobileHeroImage.srcSet.attribute,
      sizes: heroSizes,
      media: '(max-width: 63.999rem)',
      type: 'image/webp',
    },
    {
      href: desktopHeroImage.src,
      srcset: desktopHeroImage.srcSet.attribute,
      sizes: heroSizes,
      media: '(min-width: 64rem)',
      type: 'image/webp',
    },
  ]}
>
  <div class="home-site">
    <ConceptBanner />
    <SiteHeader
      mainId={mainId}
      navigation={siteNavigation}
      mobileMenuId="home-mobile-menu"
      menuAddress={venueLocationLabels.inlineAddress}
    />

    <main id={mainId} class="home-main" tabindex="-1">
      <HomeHero
        id="home-hero"
        title={homeHero.title}
        eyebrow={homeHero.eyebrow}
        intro={homeHero.intro}
        location={homeHero.location}
        action={homeHero.action}
        image={heroImagePresentation}
        responsiveSources={responsiveHeroSources}
      />

      <VisitActions id="home-visit-actions" content={venueVisitInfo} />

      <section
        class="home-manifesto ds-container"
        id="about"
        aria-label="Om Mike’s Pub"
        data-reveal
      >
        <p class="home-manifesto-kicker">På Mike’s</p>
        <p class="home-manifesto-statement">
          Musikk og kultur. <em>Fotball, dart og shuffleboard</em> omtalt i offentlige kilder.
        </p>
        <p class="home-manifesto-note">
          Programmet publiseres først når datoer og detaljer er bekreftet.
        </p>
      </section>

      <div class="home-content ds-container">
        <ProgramRail
          id="program"
          heading="Dette finner du på Mike’s"
          intro="Musikk og fotball på Mike’s. Datoer vises først når detaljene er bekreftet."
          items={homeProgramItems}
          action={{ ...venueLinks.facebook, label: 'Åpne Facebook-oppføringen' }}
        />

        <div class="home-promos" id="venue" data-reveal>
          <SportPromo id="sport" {...sportPromo} />
          <GamesPromo id="games" {...gamesPromo} />
        </div>

        <div class="home-location" id="location" data-reveal>
          <VenueMap
            id="home-location-map"
            location={verifiedSiteLocation}
            labels={venueMapLabels}
          />
          <LocationPanel
            id="home-location"
            location={verifiedSiteLocation}
            directions={venueLinks.directions}
            variant="dark"
          />
        </div>
      </div>
    </main>
  </div>
  <SiteFooter navigation={siteFooterNavigation} location={verifiedSiteLocation} />
</SiteLayout>

<script>
  import { initializeReveals } from '../scripts/reveal';

  const initialize = () => initializeReveals();
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initialize, { once: true });
  } else {
    initialize();
  }
</script>
