---
import InlineNotice from '../components/feedback/InlineNotice.astro';
import LocationPanel from '../components/location/LocationPanel.astro';
import SiteHeader from '../components/navigation/SiteHeader.astro';
import ProgramDirectory from '../components/program/ProgramDirectory.astro';
import PageIntro from '../components/program/PageIntro.astro';
import ConceptBanner from '../components/site/ConceptBanner.astro';
import SiteFooter from '../components/site/SiteFooter.astro';
import {
  conceptProgramEventListState,
  programCategories,
  programEventListState,
  programFilterDefinitions,
  programIntro,
} from '../data/program';
import {
  siteFooterNavigation,
  siteNavigation,
  venueLinks,
  verifiedSiteLocation,
} from '../data/site';
import SiteLayout from '../layouts/SiteLayout.astro';

const mainId = 'main-content';
const menuAddress = `${verifiedSiteLocation.street}, ${verifiedSiteLocation.postalCode} ${verifiedSiteLocation.city}`;
const publishedProgramState =
  programEventListState.kind === 'ready' && programEventListState.events.length > 0
    ? programEventListState
    : undefined;
const directoryState = publishedProgramState ?? conceptProgramEventListState;
const directoryHeading = publishedProgramState ? 'Bekreftet program' : 'Eksempelprogram';
const directoryMode = publishedProgramState ? 'published' : 'concept';
const showConceptNotice = !publishedProgramState;
const pageDescription = publishedProgramState
  ? 'Programoversikt for Mike’s Pub i Sætre. Bare bekreftede arrangementer vises.'
  : 'Privat designforslag til en framtidig programoversikt for Mike’s Pub i Sætre. Ingen arrangementer er bekreftet.';
---

<SiteLayout title="Program | Mike’s Pub | privat designforslag" description={pageDescription}>
  <ConceptBanner />
  <SiteHeader
    mainId={mainId}
    navigation={siteNavigation}
    currentId="program"
    mobileMenuId="program-mobile-menu"
    menuAddress={menuAddress}
  />

  <main id={mainId} class="program-main" tabindex="-1">
    <PageIntro
      id="program-intro"
      title={programIntro.title}
      intro={publishedProgramState
        ? programIntro.intro
        : 'Ingen bekreftede arrangementer er publisert ennå.'}
      eyebrow={publishedProgramState ? 'Hva skjer' : 'Programstatus'}
    />

    <div class="program-content ds-container">
      {
        showConceptNotice && (
          <InlineNotice
            id="program-concept-notice"
            className="program-concept-notice"
            variant="info"
            title="Designforslag"
            text="Oppføringene under viser hvordan et framtidig program kan se ut – de er ikke ekte arrangementer."
            action={{ ...venueLinks.facebook, label: 'Se siste nytt' }}
            headingLevel={2}
          />
        )
      }
      <ProgramDirectory
        categories={programCategories}
        filters={programFilterDefinitions}
        heading={directoryHeading}
        mode={directoryMode}
        state={directoryState}
      />

      <div class="program-location" id="location">
        <LocationPanel
          id="program-location"
          location={verifiedSiteLocation}
          directions={venueLinks.directions}
        />
      </div>
    </div>
  </main>

  <SiteFooter navigation={siteFooterNavigation} location={verifiedSiteLocation} />
</SiteLayout>
