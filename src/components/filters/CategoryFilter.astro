---
import type { CategoryFilterItem } from '../../types/design-system';

interface Props {
  categories: readonly CategoryFilterItem[];
  active?: CategoryFilterItem['value'];
  label?: string;
}

const { categories, active, label = 'Filtrer arrangementer' } = Astro.props;
---

<nav class="category-filter" aria-label={label}>
  <ul>
    {
      categories.map((category) => (
        <li>
          <a
            href={category.href}
            aria-current={active && category.value === active ? 'page' : undefined}
            data-filter-value={category.value}
            data-program-filter-link
          >
            {category.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>
