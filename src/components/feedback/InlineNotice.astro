---
import type { IconName, LinkTarget, NoticeVariant } from '../../types/design-system';
import ActionLink from '../ui/ActionLink.astro';
import Icon from '../ui/Icon.astro';

interface Props {
  id: string;
  variant: NoticeVariant;
  title: string;
  text: string;
  action?: LinkTarget;
  className?: string;
  live?: boolean;
  headingLevel?: 2 | 3;
}

const { id, variant, title, text, action, className, live = false, headingLevel = 3 } = Astro.props;
const icons: Record<NoticeVariant, IconName> = {
  info: 'info',
  warning: 'warning',
  error: 'error',
  success: 'success',
};
const Heading = `h${headingLevel}` as 'h2' | 'h3';
---

<aside
  class:list={['inline-notice', `inline-notice-${variant}`, className]}
  aria-labelledby={`${id}-title`}
  role={live ? (variant === 'error' ? 'alert' : 'status') : undefined}
>
  <Icon name={icons[variant]} />
  <div>
    <Heading id={`${id}-title`}>{title}</Heading>
    <p>{text}</p>
    {action && <ActionLink {...action} />}
  </div>
</aside>
