---
import type { HomePromoContent } from '../../types/home';
import ActionLink from '../ui/ActionLink.astro';

interface Props extends HomePromoContent {
  id: string;
}

const { id, heading, text, action } = Astro.props;
---

<section class="home-promo home-promo-games" id={id} aria-labelledby={`${id}-heading`}>
  <div class="home-promo-marker" aria-hidden="true"></div>
  <div class="home-promo-content">
    <h2 id={`${id}-heading`}>{heading}</h2>
    <p>{text}</p>
    {action && <ActionLink {...action} />}
  </div>
</section>
