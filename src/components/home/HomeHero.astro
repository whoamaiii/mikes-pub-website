---
import type { HomeHeroContent } from '../../types/home';
import ActionLink from '../ui/ActionLink.astro';

interface Props extends Omit<HomeHeroContent, 'image'> {
  id: string;
  image: {
    alt: HomeHeroContent['image']['alt'];
    focalPoint: HomeHeroContent['image']['focalPoint'];
    rightsStatus: HomeHeroContent['image']['rightsStatus'];
    mobile: Pick<HomeHeroContent['image']['mobile'], 'width' | 'height'>;
    desktop: Pick<HomeHeroContent['image']['desktop'], 'width' | 'height'>;
  };
  responsiveSources: {
    mobile: ResponsiveSource;
    desktop: ResponsiveSource;
  };
}

interface ResponsiveSource {
  src: string;
  srcset: string;
  sizes: string;
}

const { id, title, eyebrow, intro, location, action, image, responsiveSources } = Astro.props;
const [venueFirstName = title, venueSecondName = ''] = title.trim().split(/\s+/, 2);
---

<section class="home-hero" aria-labelledby={`${id}-heading`}>
  <div class="home-hero-inner ds-container">
    <div class="home-hero-content">
      <p class="home-hero-eyebrow"><span>{eyebrow}</span></p>
      <h1 id={`${id}-heading`}>
        <span class="home-hero-title-lockup">
          <span class="home-hero-title-readable">{venueFirstName}</span>{' '}
          {venueSecondName && <span class="home-hero-title-display">{venueSecondName}</span>}
        </span>
      </h1>
      <p class="home-hero-intro">{intro}</p>
      <div class="home-hero-action">
        <ActionLink {...action} variant="primary" />
      </div>
    </div>

    <div class="home-hero-meta" aria-label="Adresse">
      <span class="home-hero-meta-label">Her finner du oss</span>
      <span>{location}</span>
    </div>

    <figure
      class="home-hero-media"
      style={`--home-hero-focal-point-mobile: ${image.focalPoint.mobile}; --home-hero-focal-point-desktop: ${image.focalPoint.desktop}`}
      data-rights-status={image.rightsStatus}
    >
      <picture>
        <source
          media="(min-width: 64rem)"
          srcset={responsiveSources.desktop.srcset}
          sizes={responsiveSources.desktop.sizes}
          width={image.desktop.width}
          height={image.desktop.height}
          type="image/webp"
        />
        <img
          src={responsiveSources.mobile.src}
          srcset={responsiveSources.mobile.srcset}
          sizes={responsiveSources.mobile.sizes}
          width={image.mobile.width}
          height={image.mobile.height}
          alt={image.alt}
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </picture>
    </figure>
  </div>
</section>
