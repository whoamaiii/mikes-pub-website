---
import type { NavigationItem } from '../../types/design-system';

interface Props {
  items: NavigationItem[];
  currentId?: string;
}

const { items, currentId } = Astro.props;
---

<nav class="desktop-nav" aria-label="Hovedmeny">
  <ul>
    {
      items.map((item) => (
        <li>
          <a
            href={item.href}
            aria-label={item.accessibleLabel}
            aria-current={item.id === currentId ? 'page' : undefined}
            rel={item.external ? 'noopener noreferrer' : undefined}
          >
            {item.label}
            {item.external && <span class="visually-hidden">(ekstern lenke)</span>}
          </a>
        </li>
      ))
    }
  </ul>
</nav>
