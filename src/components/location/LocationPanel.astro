---
import type { LinkTarget, VenueLocation } from '../../types/design-system';
import ActionLink from '../ui/ActionLink.astro';

interface Props {
  id: string;
  location: VenueLocation;
  heading?: string;
  directions?: LinkTarget;
  variant?: 'paper' | 'dark';
}

const { id, location, heading, directions, variant = 'paper' } = Astro.props;
const resolvedHeading = heading ?? `Finn oss i ${location.city}`;
const streetName = location.street.replace(/\s+\d.*$/, '');
const coordinateLabel = `${location.name} / ${location.postalCode} ${location.city}`;
---

<section
  class:list={['location-panel', variant === 'dark' && 'location-panel-dark']}
  aria-labelledby={`${id}-heading`}
>
  <p class="location-panel-kicker">{streetName}</p>
  <div class="location-panel-content">
    <h2 id={`${id}-heading`}>{resolvedHeading}</h2>
    <address>
      <span>{location.name}</span>
      <span>{location.street}</span>
      <span>{location.postalCode} {location.city}</span>
    </address>
  </div>
  <span class="location-panel-coordinate" aria-hidden="true">{coordinateLabel}</span>
  {directions && <ActionLink {...directions} />}
</section>
